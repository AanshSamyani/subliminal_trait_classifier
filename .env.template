# Copy this file to `.env` on the SSH server (after cloning) and fill in values.
# `.env` is gitignored and is loaded automatically by sl/config.py (python-dotenv).

# Only needed if you later run the misalignment / paraphrase experiments that use an
# OpenAI judge. The owl + dolphin animal-preference replication does NOT use it.
OPENAI_API_KEY=

# Hugging Face token. NOT required for Qwen/Qwen2.5-7B-Instruct (public, ungated).
# Fill these in only if you switch to a gated model (e.g. some Llama/Gemma variants).
# Note: the training script reads HUGGINGFACE_TOKEN; the dataset/eval scripts read HF_TOKEN.
HF_TOKEN=
HUGGINGFACE_TOKEN=
